/*
  EINSTEIN-P Ground Station (ESP32 + RA-02 SX1278)
  Prints: RX,rssi,snr,<payload>
*/

#include <SPI.h>
#include <LoRa.h>

// Use same pins as you wired on ground station
static const int PIN_SPI_SCK  = 18;
static const int PIN_SPI_MISO = 19;
static const int PIN_SPI_MOSI = 23;

static const int PIN_LORA_CS   = 27;
static const int PIN_LORA_RST  = 14;
static const int PIN_LORA_DIO0 = 26;

static const long LORA_FREQ = 433E6;
static const int  LORA_SF = 11;
static const long LORA_BW = 125E3;
static const int  LORA_CR_DENOM = 5;
static const uint8_t LORA_SYNCWORD = 0x12;

void setup() {
  Serial.begin(115200);
  delay(200);

  SPI.begin(PIN_SPI_SCK, PIN_SPI_MISO, PIN_SPI_MOSI);

  LoRa.setPins(PIN_LORA_CS, PIN_LORA_RST, PIN_LORA_DIO0);
  if (!LoRa.begin(LORA_FREQ)) {
    Serial.println("LoRa init FAILED");
    while (true) delay(1000);
  }

  LoRa.setSpreadingFactor(LORA_SF);
  LoRa.setSignalBandwidth(LORA_BW);
  LoRa.setCodingRate4(LORA_CR_DENOM);
  LoRa.setSyncWord(LORA_SYNCWORD);
  LoRa.enableCrc();

  LoRa.receive();
  Serial.println("Ground station ready");
}

void loop() {
  int packetSize = LoRa.parsePacket();
  if (packetSize) {
    String payload;
    payload.reserve(packetSize);
    while (LoRa.available()) payload += (char)LoRa.read();

    int rssi = LoRa.packetRssi();
    float snr = LoRa.packetSnr();

    Serial.print("RX,");
    Serial.print(rssi);
    Serial.print(",");
    Serial.print(snr, 1);
    Serial.print(",");
    Serial.println(payload);
  }
}
